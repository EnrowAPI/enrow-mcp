{
  "name": "@enrow/mcp",
  "version": "1.0.0",
  "description": "MCP server for the Enrow API — find and verify professional emails, phone numbers, and contacts from any AI assistant",
  "type": "module",
  "main": "./dist/index.mjs",
  "bin": {
    "enrow-mcp": "./dist/index.mjs"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node18",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "enrow",
    "email-finder",
    "email-verifier",
    "phone-finder",
    "ai",
    "llm",
    "claude"
  ],
  "author": "Enrow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/EnrowAPI/enrow-mcp"
  },
  "homepage": "https://enrow.io",
  "engines": { "node": ">=18" },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0"
  }
}
